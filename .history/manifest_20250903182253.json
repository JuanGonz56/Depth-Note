{
    "manifest_version": 3,
    "name": "Depth Annotations",
    "version": "1.0" ,
    "description": "Create depth-aware sticky notes on webpages",
    "action": {
    "default_popup": "src/popup/popup.html"
  },
   "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["src/content/content.js"]
  }]
}